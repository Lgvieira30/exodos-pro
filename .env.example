# Servidor
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=sua_chave_secreta_muito_forte_aqui_minimo_32_chars
JWT_EXPIRES_IN=24h

# PostgreSQL local no servidor (use host.docker.internal para acessar o banco do host)
# DATABASE_URL=postgresql://usuario:senha@host.docker.internal:5432/nome_do_banco
# PostgreSQL remoto (Neon)
# DATABASE_URL=postgresql://usuario:senha@host.neon.tech/exodos_pro?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host.docker.internal:5432/nome_do_banco

# Frontend (CORS — deixe vazio se frontend e backend estão na mesma URL)
FRONTEND_URL=

# Meta Ads (opcional)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads (opcional)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
